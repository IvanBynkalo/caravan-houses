# Railway подставляет PORT автоматически — не менять
PORT=3000
DATABASE_PATH=./data/caravan.db

# ОБЯЗАТЕЛЬНО заполнить в Railway Variables
JWT_SECRET=замените-на-случайную-строку-минимум-32-символа
TELEGRAM_BOT_TOKEN=токен-от-BotFather

# URL фронтенда на Vercel (для CORS)
# Формат: https://ваш-проект.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

NODE_ENV=production
