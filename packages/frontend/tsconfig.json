{
  "compilerOptions": {
    "target":           "ES2022",
    "lib":              ["ES2022", "DOM", "DOM.Iterable"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "jsx":              "react-jsx",
    "strict":           true,
    "skipLibCheck":     true,
    "resolveJsonModule": true,
    "noEmit":           true,
    "esModuleInterop":  true,
    "paths": {
      "@caravan/shared": ["../../shared/src/index.ts"]
    }
  },
  "include": ["src"]
}
